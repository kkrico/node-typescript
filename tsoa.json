{
  "entryFile": "src/app.ts",
  "noImplicitAdditionalProperties": "throw-on-extras",
  "controllerPathGlobs": ["src/**/*Controller.ts"],
  "spec": {
    "outputDirectory": "build",
    "specVersion": 3,
    "basePath": "/api/v1",
    "securityDefinitions": {
      "Bearer": {
        "type": "apiKey",
        "name": "Authorization",
        "in": "header"
      }
    }
  },
  "routes": {
    "routesDir": "build",
    "basePath": "/api/v1",
    "iocModule": "src/app/ioc",
    "authenticationModule": "src/app/autenticacao"
  },
  "ignore": ["**/node_modules/**"]
}
